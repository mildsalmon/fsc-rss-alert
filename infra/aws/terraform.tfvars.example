aws_region        = "ap-northeast-2"
project_name      = "feed-collector"
environment       = "prod"
github_repository = "mildsalmon/fsc-rss-alert"
github_branch     = "main"

# Use the default VPC/subnet by default. Set these when deploying into a specific VPC.
# vpc_id    = "vpc-..."
# subnet_id = "subnet-..."
#
# Public IPv4 is enabled by default so the instance has simple outbound HTTPS
# access for ECR pulls, RSS fetches, and Slack sends in a public subnet.
# Set this to false only when the selected subnet has another outbound egress path.
# associate_public_ip_address = false

instance_type       = "t3.micro"
root_volume_size_gb = 12

# Optional SSH access. Leave empty for outbound-only security group.
# key_name                = "your-key-pair"
# ssh_ingress_cidr_blocks = ["203.0.113.10/32"]

# Optional secret bootstrap. Create this SecureString manually first:
# aws ssm put-parameter --name /feed-collector/prod/slack-bot-token --type SecureString --value 'xoxb-...' --overwrite
# slack_bot_token_parameter_name = "/feed-collector/prod/slack-bot-token"
